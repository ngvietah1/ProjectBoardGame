<Window x:Class="UIBoardGame.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UIBoardGame"
        mc:Ignorable="d"
        Title="Addboardgame" Height="500" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Background="Black" Grid.Column="0"></Grid>
        <Border CornerRadius="20" Margin="10,10,5,10">
            <Border.Background>
                <ImageBrush x:Name="mainimage" Stretch="UniformToFill"></ImageBrush>
            </Border.Background>
        </Border>
        <StackPanel Margin="20" Grid.Column="0">
            <TextBlock Text="Тип:" FontSize="15" FontFamily="Times New Roman" Foreground="AntiqueWhite"></TextBlock>
            <ComboBox x:Name="cbbtype" HorizontalAlignment="Left" Width="90" Height="25" SelectionChanged="cbbtype_SelectionChanged" FontFamily="Times New Roman" Cursor="Hand"></ComboBox>
            <TextBlock Text="Название:" FontSize="15" Margin="0,10,0,0" Foreground="AntiqueWhite" FontFamily="Times New Roman"></TextBlock>
            <TextBox x:Name="tbname" Text="Название" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" FontFamily="Times New Roman"></TextBox>
            <TextBlock Text="Количество игроков:" Margin="0,10,0,0" FontSize="15" FontFamily="Times New Roman" Foreground="AntiqueWhite"></TextBlock>
            <TextBox x:Name="tbminplayers" Text="Минимальное количество" FontSize="12" FontStyle="Italic" FontFamily="Times New Roman"></TextBox>
            <TextBox x:Name="tbmaxplayers" Text="Максимальное количество" FontSize="12" FontStyle="Italic" FontFamily="Times New Roman"></TextBox>
            <TextBlock Text="Возрастное ограничение:" FontSize="15" Margin="0,10,0,0" FontFamily="Times New Roman" Foreground="AntiqueWhite"></TextBlock>
            <TextBox x:Name="tbagelimit" Text="Возраст" FontStyle="Italic" FontFamily="Times New Roman"></TextBox>
            <TextBlock Text="Описание:" FontSize="15" Margin="0,10,0,0" FontFamily="Times New Roman" Foreground="AntiqueWhite"></TextBlock>
            <TextBox x:Name="tbdescrition" Text="Описание" FontStyle="Italic" TextWrapping="Wrap" FontFamily="Times New Roman"></TextBox>
        </StackPanel>
        <Grid Background="Black" Grid.Column="1">
            <Border CornerRadius="20" Margin="5,10,10,10">
                <Border.Background>
                    <ImageBrush x:Name="addimage2" Stretch="UniformToFill"></ImageBrush>
                </Border.Background>
            </Border>
        </Grid>
        <StackPanel Grid.Column="1" Margin="20">
            <TextBlock x:Name="parameter1" Text="example" FontSize="15" FontFamily="Times New Roman"></TextBlock>
            <TextBox x:Name="inputparameter1" Text="example" FontSize="12" FontStyle="Italic" FontFamily="Times New Roman"></TextBox>
            <TextBlock x:Name="parameter2" Text="example" FontSize="15" Margin="0,10,0,0" FontFamily="Times New Roman"></TextBlock>
            <TextBox x:Name="inputparameter2" Text="example" FontSize="12" FontStyle="Italic" FontFamily="Times New Roman"></TextBox>
            <ComboBox x:Name="inputparameter3" HorizontalAlignment="Left" Width="60" Height="25" FontFamily="Times New Roman" Cursor="Hand"></ComboBox>
        </StackPanel>
        <Button x:Name="savebtn" Grid.Column="1" VerticalAlignment="Bottom" Margin="18" Content="Сохранить" HorizontalAlignment="Right" FontSize="15" Click="savebtn_Click" FontFamily="Times New Roman" Background="SteelBlue" Foreground="AntiqueWhite" Cursor="Hand"></Button>
        <Button x:Name="checktn" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="18" Content="Проверить" FontSize="15" Click="checktn_Click" FontFamily="Times New Roman" Foreground="AntiqueWhite" Background="SteelBlue" Cursor="Hand"></Button>
    </Grid>
</Window>
