<Window x:Class="UIBoardGame.NewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UIBoardGame"
        mc:Ignorable="d"
        Title="NewWindow" Height="500" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>
        <Image x:Name="image" Grid.Row="0" Stretch="UniformToFill"></Image>
        <Grid Grid.Column="0" Background="SteelBlue" x:Name="grid2">
            <TextBlock x:Name="txtblock2" Grid.Row="0" Foreground="AntiqueWhite" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="60" FontFamily="Times New Roman"></TextBlock>
        </Grid>
        <Grid Grid.Row="1" Background="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Image x:Name="mainnewwinimage" Stretch="UniformToFill" Grid.Column="1"></Image>
            <TextBlock Grid.Column="0" x:Name="txtblock" Foreground="LightGoldenrodYellow" TextWrapping="Wrap" FontFamily="Times New Roman" FontSize="20" Margin="10"></TextBlock>
        </Grid>
    </Grid>
</Window>
